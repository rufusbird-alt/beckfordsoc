# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.

# ─── WordPress migration (one-time / run locally) ─────────────────────────────
# Used by `npm run migrate:wp` to pull content from the existing site.
WP_URL=https://beckfordsociety.org
WP_USER=admin
WP_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"

# ─── Stripe (Join the Society) ────────────────────────────────────────────────
# Add once Stripe account is set up.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Site metadata ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://beckfordsociety.org
NEXT_PUBLIC_SITE_EMAIL=contact@beckfordsociety.org
